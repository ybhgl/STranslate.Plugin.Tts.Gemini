<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Url">API URL</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Url_Placeholder">https://generativelanguage.googleapis.com</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_ApiKey">API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_ApiKey_Description">Click to learn how to get API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_ApiKey_Placeholder">Enter your API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_ApiKey_Empty">Please configure API Key first</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Model">Model</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Voice">Voice</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Voice_Description">Click to view available voices</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Text_Empty">Text content cannot be empty</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Audio_Empty">API returned empty audio data</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Parse_Error">Failed to parse API response</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Decode_Error">Failed to decode audio data</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Support">Support</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Support_Description">This plugin is based on Google Gemini TTS API</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_IsStreaming">Streaming</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_IsStreaming_Description">Only works on models that support streaming</sys:String>

</ResourceDictionary>
