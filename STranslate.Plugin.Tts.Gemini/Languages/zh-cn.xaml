<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Url">接口地址</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Url_Placeholder">https://generativelanguage.googleapis.com</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_ApiKey">API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_ApiKey_Description">点击查看如何获取API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_ApiKey_Placeholder">请输入API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_ApiKey_Empty">请先配置API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Model">模型</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Voice">音色</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Voice_Description">点击查看可用音色列表</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Text_Empty">文本内容不能为空</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Audio_Empty">API返回的音频数据为空</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Parse_Error">解析API响应失败</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Decode_Error">音频数据解码失败</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Support">支持</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Support_Description">此插件基于 Google Gemini 语音合成 API</sys:String>

</ResourceDictionary>
