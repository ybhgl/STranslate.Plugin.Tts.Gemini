    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Url">介面地址</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_Url_Placeholder">https://generativelanguage.googleapis.com</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_ApiKey">API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_ApiKey_Description">點擊查看如何取得API Key</sys:String>
    <sys:String x:Key="STranslate_Plugin_Tts_Gemini_ApiKey_Placeholder">請輸入API Key</sys:String>
